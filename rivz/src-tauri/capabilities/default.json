{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    {
      "identifier": "opener:default",
      "allow": [
        { "url": "http://localhost:8080/*" },
        { "url": "https://*" }
      ]
    },
    "deep-link:default"
  ]
}